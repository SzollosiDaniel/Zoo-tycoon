<Window x:Class="Zoo_tycoon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zoo_tycoon"
        mc:Ignorable="d"
        Title="MainWindow" Height="923" Width="1615">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border BorderThickness="5px" BorderBrush="Black" CornerRadius="10"  Height="75" Width="1600">
            <Canvas Background="SaddleBrown">
                <TextBlock Width="auto" Margin="0,10,0,0" Height="auto" Text="Zoo name" FontSize="30" Foreground="White"/>
                <Image Source="/Images/MenuIcons/customer.png" Height="40" Margin="350,13,0,0"/>
                <TextBlock Width="auto" Margin="400,20,0,0" Height="auto" Text="Customers" FontSize="22" Foreground="White"/>
                <Image Source="/Images/MenuIcons/money.png" Margin="750,16,0,0" Height="40"/>
                <TextBlock Width="auto" Margin="800,20,0,0" Height="auto" Text="Money" FontSize="22" Foreground="LightGreen"/>
                <TextBlock Width="auto" Margin="1400,20,0,0" Height="auto" Text="time" FontSize="22" Foreground="White"/>
                <Image Source="/Images/MenuIcons/sun.png" Height="40" Margin="1350,15,0,0"/>
            </Canvas>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Grid Name="MainGameGrid" Width="1150" Height="809.04" Background="Green"/>

            <Border Grid.Column="2" BorderThickness="3" BorderBrush="Black" Height="825" Margin="0,0,0,0" Name="MenuBarBorder" Width="450">
                <Grid Background="SaddleBrown" Name="MenuBar">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="75"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Height="60" Width="135" Background="DeepSkyBlue" Content="Builds" FontSize="20" Click="ShowBuilds" Grid.Column="0"/>
                    <Button Height="60" Width="135" Background="DeepSkyBlue" Content="Shops" FontSize="20" Grid.Column="1"/>
                    <Button Height="60" Width="135" Background="DeepSkyBlue" Content="Stats" FontSize="20" Grid.Column="3"/>
                </Grid>

            </Border>
            <Canvas Name="MainGameCanvas"  Width="1150" Height="809.04" HorizontalAlignment="Left">
                <Rectangle Name="MouseTrackingRectangle" Fill="LightGray" Opacity="0.8" Visibility="Collapsed" Width="53.48" Height="53.93" Canvas.Left="-100"/>
            </Canvas>
        </Grid>
    </Grid>
</Window>
